# Admin User Credentials
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=your-secure-password

# Database (Docker)
DATABASE_HOST=db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Rails Credentials (Production only - use config/master.key in dev)
# RAILS_MASTER_KEY=your_master_key_content_here

# Rails Environment
RAILS_ENV=development
RAILS_MAX_THREADS=5

# Google OAuth 2.0 (Login via Google)
# Obtenha em: https://console.cloud.google.com/ → APIs e Serviços → Credenciais
# Redirect URI a configurar no Google: http://localhost:3001/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
