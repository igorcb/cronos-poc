<turbo-frame id="modal">
  <% if request.headers["Turbo-Frame"] == "modal" %>
    <!-- Overlay modal quando renderizado dentro do frame -->
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 overflow-y-auto"
         data-controller="modal"
         data-action="click->modal#closeOnOverlayClick">
      <div class="relative w-full sm:max-w-2xl mx-4 my-8">
        <div class="bg-gray-800 shadow-xl rounded-lg p-4 sm:p-6 border border-gray-700">
          <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-white">Nova Tarefa</h1>
            <button type="button"
                    data-action="click->modal#close"
                    aria-label="Fechar modal"
                    class="text-gray-400 hover:text-white transition min-h-[44px] min-w-[44px] flex items-center justify-center rounded-md hover:bg-gray-700">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <%= form_with(model: @task, data: { controller: "project-selector form-validation", turbo: "true" }, html: { novalidate: true }) do |f| %>
            <% if @task.errors.any? %>
              <div role="alert" class="bg-red-900/50 border border-red-500 text-red-200 px-4 py-3 rounded-md mb-4">
                <h2 class="font-bold mb-2">
                  <%= pluralize(@task.errors.count, "erro encontrado:", "erros encontrados:") %>
                </h2>
                <ul class="list-disc list-inside space-y-1">
                  <% @task.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="space-y-4">
              <!-- Company -->
              <div>
                <%= f.label :company_id, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                  Empresa
                  <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                <% end %>
                <%= f.collection_select :company_id, @companies, :id, :name,
                    { prompt: "Selecione uma empresa" },
                    "aria-required": "true",
                    "aria-describedby": @task.errors[:company_id].any? ? "task_company_id_error" : nil,
                    "aria-invalid": @task.errors[:company_id].any? ? "true" : nil,
                    data: { project_selector_target: "companySelect", action: "change->project-selector#loadProjects change->form-validation#clearError" },
                    class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:company_id].any? ? 'border-red-500' : 'border-gray-600'}" %>
                <% if @task.errors[:company_id].any? %>
                  <span id="task_company_id_error" role="alert" class="mt-1 text-sm text-red-400">
                    <%= @task.errors[:company_id].first %>
                  </span>
                <% end %>
              </div>

              <!-- Project -->
              <div>
                <%= f.label :project_id, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                  Projeto
                  <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                <% end %>
                <%= f.select :project_id, [],
                    { prompt: "Selecione um projeto" },
                    "aria-required": "true",
                    "aria-describedby": @task.errors[:project_id].any? ? "task_project_id_error" : nil,
                    "aria-invalid": @task.errors[:project_id].any? ? "true" : nil,
                    data: { project_selector_target: "projectSelect", action: "change->form-validation#clearError" },
                    class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:project_id].any? ? 'border-red-500' : 'border-gray-600'}",
                    disabled: true %>
                <% if @task.errors[:project_id].any? %>
                  <span id="task_project_id_error" role="alert" class="mt-1 text-sm text-red-400">
                    <%= @task.errors[:project_id].first %>
                  </span>
                <% end %>
              </div>

              <!-- Code -->
              <div>
                <%= f.label :code, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                  Código
                  <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                <% end %>
                <%= f.text_field :code,
                    "aria-required": "true",
                    placeholder: "Ex: 14335",
                    inputmode: "numeric",
                    pattern: "[0-9]*",
                    "aria-describedby": @task.errors[:code].any? ? "task_code_error" : nil,
                    "aria-invalid": @task.errors[:code].any? ? "true" : nil,
                    data: { action: "input->form-validation#clearError" },
                    class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:code].any? ? 'border-red-500' : 'border-gray-600'}" %>
                <% if @task.errors[:code].any? %>
                  <span id="task_code_error" role="alert" class="mt-1 text-sm text-red-400">
                    <%= @task.errors[:code].first %>
                  </span>
                <% end %>
              </div>

              <!-- Name -->
              <div>
                <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                  Nome da Tarefa
                  <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                <% end %>
                <%= f.text_field :name,
                    "aria-required": "true",
                    "aria-describedby": @task.errors[:name].any? ? "task_name_error" : nil,
                    "aria-invalid": @task.errors[:name].any? ? "true" : nil,
                    data: { action: "input->form-validation#clearError" },
                    class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:name].any? ? 'border-red-500' : 'border-gray-600'}" %>
                <% if @task.errors[:name].any? %>
                  <span id="task_name_error" role="alert" class="mt-1 text-sm text-red-400">
                    <%= @task.errors[:name].first %>
                  </span>
                <% end %>
              </div>

              <!-- Estimated Hours and Start Date -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <%= f.label :estimated_hours_hm, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                    Horas Estimadas (HH:MM)
                    <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                  <% end %>
                  <%= f.text_field :estimated_hours_hm,
                      placeholder: "03:00",
                      pattern: "\\d{1,2}:\\d{2}",
                      inputmode: "numeric",
                      title: "Formato HH:MM (ex: 03:00, 02:30, 18:00)",
                      "aria-required": "true",
                      "aria-describedby": @task.errors[:estimated_hours_hm].any? ? "task_estimated_hours_hm_error" : "estimated-hours-hint",
                      "aria-invalid": @task.errors[:estimated_hours_hm].any? ? "true" : nil,
                      data: { action: "input->form-validation#clearError" },
                      class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:estimated_hours_hm].any? ? 'border-red-500' : 'border-gray-600'}" %>
                  <p id="estimated-hours-hint" class="mt-1 text-xs text-gray-400">Formato: HH:MM (ex: 03:00, 02:30, 18:00)</p>
                  <% if @task.errors[:estimated_hours_hm].any? %>
                    <span id="task_estimated_hours_hm_error" role="alert" class="mt-1 text-sm text-red-400">
                      <%= @task.errors[:estimated_hours_hm].first %>
                    </span>
                  <% end %>
                </div>

                <div>
                  <%= f.label :start_date, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                    Data de Início
                    <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                  <% end %>
                  <%= f.date_field :start_date,
                      value: Date.today,
                      "aria-required": "true",
                      "aria-describedby": @task.errors[:start_date].any? ? "task_start_date_error" : nil,
                      "aria-invalid": @task.errors[:start_date].any? ? "true" : nil,
                      data: { action: "input->form-validation#clearError" },
                      class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:start_date].any? ? 'border-red-500' : 'border-gray-600'}" %>
                  <% if @task.errors[:start_date].any? %>
                    <span id="task_start_date_error" role="alert" class="mt-1 text-sm text-red-400">
                      <%= @task.errors[:start_date].first %>
                    </span>
                  <% end %>
                </div>
              </div>

              <!-- Status -->
              <div>
                <%= f.label :status, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                  Status
                  <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                <% end %>
                <%= f.select :status,
                    Task.statuses.keys.map { |s| [I18n.t("task.status.#{s}", default: s.humanize), s] },
                    { selected: @task.status || "pending" },
                    "aria-required": "true",
                    class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border border-gray-600" %>
              </div>

              <!-- Notes -->
              <div>
                <%= f.label :notes, "Observações", class: "block text-sm font-medium text-gray-300 mb-1" %>
                <%= f.text_area :notes, rows: 3, class: "w-full min-h-[88px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
              </div>

              <p class="text-xs text-gray-400"><span class="text-red-400">*</span> campos obrigatórios</p>

              <!-- Submit -->
              <div class="flex flex-col sm:flex-row gap-3 pt-2">
                <%= f.submit "Salvar",
                    class: "w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg text-lg font-semibold transition min-h-[44px] cursor-pointer" %>
                <button type="button"
                        data-action="click->modal#close"
                        class="bg-gray-600 hover:bg-gray-500 text-white px-6 py-2 rounded-md text-sm font-medium transition min-h-[44px] inline-flex items-center justify-center">
                  Cancelar
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Renderização normal fora do modal -->
    <div class="w-full sm:max-w-2xl sm:mx-auto">
      <div class="bg-gray-800 shadow-sm rounded-lg p-4 sm:p-6 border border-gray-700">
        <h1 class="text-2xl font-bold text-white mb-6">Nova Tarefa</h1>

        <%= form_with(model: @task, data: { controller: "project-selector form-validation", turbo: "false" }, html: { novalidate: true }) do |f| %>
          <% if @task.errors.any? %>
            <div role="alert" class="bg-red-900/50 border border-red-500 text-red-200 px-4 py-3 rounded-md">
              <h2 class="font-bold mb-2">
                <%= pluralize(@task.errors.count, "erro encontrado:", "erros encontrados:") %>
              </h2>
              <ul class="list-disc list-inside space-y-1">
                <% @task.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="space-y-6">
            <!-- Company -->
            <div>
              <%= f.label :company_id, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                Empresa
                <span class="text-red-400 ml-1" aria-hidden="true">*</span>
              <% end %>
              <%= f.collection_select :company_id, @companies, :id, :name,
                  { prompt: "Selecione uma empresa" },
                  "aria-required": "true",
                  "aria-describedby": @task.errors[:company_id].any? ? "task_company_id_error" : nil,
                  "aria-invalid": @task.errors[:company_id].any? ? "true" : nil,
                  data: { project_selector_target: "companySelect", action: "change->project-selector#loadProjects change->form-validation#clearError" },
                  class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:company_id].any? ? 'border-red-500' : 'border-gray-600'}" %>
              <% if @task.errors[:company_id].any? %>
                <span id="task_company_id_error" role="alert" class="mt-1 text-sm text-red-400">
                  <%= @task.errors[:company_id].first %>
                </span>
              <% end %>
            </div>

            <!-- Project -->
            <div>
              <%= f.label :project_id, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                Projeto
                <span class="text-red-400 ml-1" aria-hidden="true">*</span>
              <% end %>
              <%= f.select :project_id, [],
                  { prompt: "Selecione um projeto" },
                  "aria-required": "true",
                  "aria-describedby": @task.errors[:project_id].any? ? "task_project_id_error" : nil,
                  "aria-invalid": @task.errors[:project_id].any? ? "true" : nil,
                  data: { project_selector_target: "projectSelect", action: "change->form-validation#clearError" },
                  class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:project_id].any? ? 'border-red-500' : 'border-gray-600'}",
                  disabled: true %>
              <% if @task.errors[:project_id].any? %>
                <span id="task_project_id_error" role="alert" class="mt-1 text-sm text-red-400">
                  <%= @task.errors[:project_id].first %>
                </span>
              <% end %>
            </div>

            <!-- Code -->
            <div>
              <%= f.label :code, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                Código
                <span class="text-red-400 ml-1" aria-hidden="true">*</span>
              <% end %>
              <%= f.text_field :code,
                  "aria-required": "true",
                  placeholder: "Ex: 14335",
                  inputmode: "numeric",
                  pattern: "[0-9]*",
                  "aria-describedby": @task.errors[:code].any? ? "task_code_error" : nil,
                  "aria-invalid": @task.errors[:code].any? ? "true" : nil,
                  data: { action: "input->form-validation#clearError" },
                  class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:code].any? ? 'border-red-500' : 'border-gray-600'}" %>
              <% if @task.errors[:code].any? %>
                <span id="task_code_error" role="alert" class="mt-1 text-sm text-red-400">
                  <%= @task.errors[:code].first %>
                </span>
              <% end %>
            </div>

            <!-- Name -->
            <div>
              <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                Nome da Tarefa
                <span class="text-red-400 ml-1" aria-hidden="true">*</span>
              <% end %>
              <%= f.text_field :name,
                  "aria-required": "true",
                  "aria-describedby": @task.errors[:name].any? ? "task_name_error" : nil,
                  "aria-invalid": @task.errors[:name].any? ? "true" : nil,
                  data: { action: "input->form-validation#clearError" },
                  class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:name].any? ? 'border-red-500' : 'border-gray-600'}" %>
              <% if @task.errors[:name].any? %>
                <span id="task_name_error" role="alert" class="mt-1 text-sm text-red-400">
                  <%= @task.errors[:name].first %>
                </span>
              <% end %>
            </div>

            <!-- Estimated Hours and Start Date (same row) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <%= f.label :estimated_hours_hm, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                  Horas Estimadas (HH:MM)
                  <span class="text-red-400 ml-1" aria-hidden="true">*</span>
                <% end %>
                <%= f.text_field :estimated_hours_hm,
                    placeholder: "03:00",
                    pattern: "\\d{1,2}:\\d{2}",
                    inputmode: "numeric",
                    title: "Formato HH:MM (ex: 03:00, 02:30, 18:00)",
                    "aria-required": "true",
                    "aria-describedby": @task.errors[:estimated_hours_hm].any? ? "task_estimated_hours_hm_error" : "estimated-hours-hint",
                    "aria-invalid": @task.errors[:estimated_hours_hm].any? ? "true" : nil,
                    data: { action: "input->form-validation#clearError" },
                    class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent border #{@task.errors[:estimated_hours_hm].any? ? 'border-red-500' : 'border-gray-600'}" %>
                <p id="estimated-hours-hint" class="mt-1 text-xs text-gray-400">Formato: HH:MM (ex: 03:00, 02:30, 18:00)</p>
                <% if @task.errors[:estimated_hours_hm].any? %>
                  <span id="task_estimated_hours_hm_error" role="alert" class="mt-1 text-sm text-red-400">
                    <%= @task.errors[:estimated_hours_hm].first %>
                  </span>
                <% end %>
              </div>

              <div>
                <%= f.label :start_date, class: "block text-sm font-medium text-gray-300 mb-1" do %>
                  Data de Início
