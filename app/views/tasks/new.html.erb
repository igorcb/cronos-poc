<div class="w-full sm:max-w-2xl sm:mx-auto">
  <div class="bg-gray-800 shadow-sm rounded-lg p-4 sm:p-6 border border-gray-700">
    <h1 class="text-2xl font-bold text-white mb-6">Nova Tarefa</h1>

    <%= form_with(model: @task, data: { controller: "project-selector" }) do |f| %>
      <% if @task.errors.any? %>
        <div role="alert" class="bg-red-900/50 border border-red-500 text-red-200 px-4 py-3 rounded-md">
          <h2 class="font-bold mb-2">
            <%= pluralize(@task.errors.count, "erro encontrado:", "erros encontrados:") %>
          </h2>
          <ul class="list-disc list-inside space-y-1">
            <% @task.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-6">
        <!-- Company -->
        <div>
          <%= f.label :company_id, "Empresa", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.collection_select :company_id, @companies, :id, :name,
              { prompt: "Selecione uma empresa" },
              data: { project_selector_target: "companySelect", action: "change->project-selector#loadProjects" },
              class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              required: true,
              "aria-required": "true",
              "aria-describedby": @task.errors[:company_id].any? ? "task_company_id_error" : nil,
              "aria-invalid": @task.errors[:company_id].any? ? "true" : nil %>
          <% if @task.errors[:company_id].any? %>
            <span id="task_company_id_error" role="alert" class="mt-1 text-sm text-red-400">
              <%= @task.errors[:company_id].first %>
            </span>
          <% end %>
        </div>

        <!-- Project -->
        <div>
          <%= f.label :project_id, "Projeto", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.select :project_id, [],
              { prompt: "Selecione um projeto" },
              data: { project_selector_target: "projectSelect" },
              class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              required: true,
              "aria-required": "true",
              "aria-describedby": @task.errors[:project_id].any? ? "task_project_id_error" : nil,
              "aria-invalid": @task.errors[:project_id].any? ? "true" : nil %>
          <% if @task.errors[:project_id].any? %>
            <span id="task_project_id_error" role="alert" class="mt-1 text-sm text-red-400">
              <%= @task.errors[:project_id].first %>
            </span>
          <% end %>
        </div>

        <!-- Name -->
        <div>
          <%= f.label :name, "Nome da Tarefa", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.text_field :name,
              class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              required: true,
              "aria-required": "true",
              "aria-describedby": @task.errors[:name].any? ? "task_name_error" : nil,
              "aria-invalid": @task.errors[:name].any? ? "true" : nil %>
          <% if @task.errors[:name].any? %>
            <span id="task_name_error" role="alert" class="mt-1 text-sm text-red-400">
              <%= @task.errors[:name].first %>
            </span>
          <% end %>
        </div>

        <!-- Estimated Hours and Start Date (same row) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Estimated Hours (HH:MM format) -->
          <div>
            <%= f.label :estimated_hours_hm, "Horas Estimadas (HH:MM)", class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.text_field :estimated_hours_hm,
                placeholder: "03:00",
                class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
                required: true,
                pattern: "\\d{1,2}:\\d{2}",
                inputmode: "numeric",
                title: "Formato HH:MM (ex: 03:00, 02:30, 18:00)",
                "aria-required": "true",
                "aria-describedby": @task.errors[:estimated_hours_hm].any? ? "task_estimated_hours_hm_error" : "estimated-hours-hint",
                "aria-invalid": @task.errors[:estimated_hours_hm].any? ? "true" : nil %>
            <p id="estimated-hours-hint" class="mt-1 text-xs text-gray-400">Formato: HH:MM (ex: 03:00, 02:30, 18:00)</p>
            <% if @task.errors[:estimated_hours_hm].any? %>
              <span id="task_estimated_hours_hm_error" role="alert" class="mt-1 text-sm text-red-400">
                <%= @task.errors[:estimated_hours_hm].first %>
              </span>
            <% end %>
          </div>

          <!-- Start Date -->
          <div>
            <%= f.label :start_date, "Data de Início", class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.date_field :start_date,
                value: Date.today,
                class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
                required: true,
                "aria-required": "true",
                "aria-describedby": @task.errors[:start_date].any? ? "task_start_date_error" : nil,
                "aria-invalid": @task.errors[:start_date].any? ? "true" : nil %>
            <% if @task.errors[:start_date].any? %>
              <span id="task_start_date_error" role="alert" class="mt-1 text-sm text-red-400">
                <%= @task.errors[:start_date].first %>
              </span>
            <% end %>
          </div>
        </div>

        <!-- Notes -->
        <div>
          <%= f.label :notes, "Observações", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.text_area :notes, rows: 4, class: "w-full min-h-[88px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        </div>

        <!-- Submit -->
        <div class="flex flex-col sm:flex-row gap-3 pt-4">
          <%= f.submit "Criar Tarefa",
              class: "w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg text-lg font-semibold transition min-h-[44px] cursor-pointer" %>
          <%= link_to "Cancelar", root_path,
              class: "bg-gray-600 hover:bg-gray-500 text-white px-6 py-2 rounded-md text-sm font-medium transition min-h-[44px] inline-flex items-center justify-center",
              aria: { label: "Cancelar e voltar ao início" } %>
        </div>
      </div>
    <% end %>
  </div>
</div>
