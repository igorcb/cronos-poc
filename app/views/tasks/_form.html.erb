<%= form_with(model: task, class: "space-y-6",
    data: { controller: "project-selector form-validation" },
    novalidate: true) do |form| %>
  <% if task.errors.any? %>
    <div role="alert" class="bg-red-900/50 border border-red-500 text-red-200 px-4 py-3 rounded-md">
      <h2 class="font-bold mb-2">
        <%= pluralize(task.errors.count, "erro encontrado", "erros encontrados") %>:
      </h2>
      <ul class="list-disc list-inside space-y-1">
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-300 mb-1" do %>
      Nome da Tarefa
      <span class="text-red-400 ml-1" aria-hidden="true">*</span>
    <% end %>
    <%= form.text_field :name,
        "aria-required": "true",
        "aria-describedby": task.errors[:name].any? ? "task_name_error" : nil,
        "aria-invalid": task.errors[:name].any? ? "true" : nil,
        data: { action: "input->form-validation#clearError" },
        class: "mt-1 block w-full rounded-md bg-gray-700 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border #{task.errors[:name].any? ? 'border-red-500' : 'border-gray-600'}",
        placeholder: "Nome da tarefa" %>
    <% if task.errors[:name].any? %>
      <span id="task_name_error" role="alert" class="mt-1 text-sm text-red-400">
        <%= task.errors[:name].first %>
      </span>
    <% end %>
  </div>

  <div>
    <%= form.label :company_id, class: "block text-sm font-medium text-gray-300 mb-1" do %>
      Empresa
      <span class="text-red-400 ml-1" aria-hidden="true">*</span>
    <% end %>
    <%= form.collection_select :company_id, companies, :id, :name,
        { prompt: "Selecione uma empresa" },
        {
          "aria-required": "true",
          "aria-describedby": task.errors[:company_id].any? ? "task_company_error" : nil,
          "aria-invalid": task.errors[:company_id].any? ? "true" : nil,
          class: "mt-1 block w-full rounded-md bg-gray-700 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border #{task.errors[:company_id].any? ? 'border-red-500' : 'border-gray-600'}",
          data: { project_selector_target: "companySelect", action: "change->project-selector#loadProjects change->form-validation#clearError" }
        } %>
    <% if task.errors[:company_id].any? %>
      <span id="task_company_error" role="alert" class="mt-1 text-sm text-red-400">
        <%= task.errors[:company_id].first %>
      </span>
    <% end %>
  </div>

  <div>
    <%= form.label :project_id, class: "block text-sm font-medium text-gray-300 mb-1" do %>
      Projeto
      <span class="text-red-400 ml-1" aria-hidden="true">*</span>
    <% end %>
    <%= form.select :project_id,
        [],
        { prompt: "Selecione uma empresa primeiro" },
        {
          "aria-required": "true",
          "aria-describedby": task.errors[:project_id].any? ? "task_project_error" : "project-hint",
          "aria-invalid": task.errors[:project_id].any? ? "true" : nil,
          class: "mt-1 block w-full rounded-md bg-gray-700 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border #{task.errors[:project_id].any? ? 'border-red-500' : 'border-gray-600'}",
          data: { project_selector_target: "projectSelect", action: "change->form-validation#clearError" },
          disabled: true
        } %>
    <p class="mt-1 text-sm text-gray-400" id="project-hint"></p>
    <% if task.errors[:project_id].any? %>
      <span id="task_project_error" role="alert" class="mt-1 text-sm text-red-400">
        <%= task.errors[:project_id].first %>
      </span>
    <% end %>
  </div>

  <div>
    <%= form.label :start_date, class: "block text-sm font-medium text-gray-300 mb-1" do %>
      Data de Início
      <span class="text-red-400 ml-1" aria-hidden="true">*</span>
    <% end %>
    <%= form.date_field :start_date,
        value: Date.today,
        "aria-required": "true",
        "aria-describedby": task.errors[:start_date].any? ? "task_start_date_error" : nil,
        "aria-invalid": task.errors[:start_date].any? ? "true" : nil,
        data: { action: "input->form-validation#clearError" },
        class: "mt-1 block w-full rounded-md bg-gray-700 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border #{task.errors[:start_date].any? ? 'border-red-500' : 'border-gray-600'}" %>
    <% if task.errors[:start_date].any? %>
      <span id="task_start_date_error" role="alert" class="mt-1 text-sm text-red-400">
        <%= task.errors[:start_date].first %>
      </span>
    <% end %>
  </div>

  <div>
    <%= form.label :estimated_hours, class: "block text-sm font-medium text-gray-300 mb-1" do %>
      Horas Estimadas
      <span class="text-red-400 ml-1" aria-hidden="true">*</span>
    <% end %>
    <%= form.number_field :estimated_hours,
        step: 0.01,
        min: 0.01,
        "aria-required": "true",
        "aria-describedby": task.errors[:estimated_hours].any? ? "task_estimated_hours_error" : nil,
        "aria-invalid": task.errors[:estimated_hours].any? ? "true" : nil,
        data: { action: "input->form-validation#clearError" },
        class: "mt-1 block w-full rounded-md bg-gray-700 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border #{task.errors[:estimated_hours].any? ? 'border-red-500' : 'border-gray-600'}",
        placeholder: "8.0" %>
    <% if task.errors[:estimated_hours].any? %>
      <span id="task_estimated_hours_error" role="alert" class="mt-1 text-sm text-red-400">
        <%= task.errors[:estimated_hours].first %>
      </span>
    <% end %>
  </div>

  <div>
    <%= form.label :notes, "Observações", class: "block text-sm font-medium text-gray-300 mb-1" %>
    <%= form.text_area :notes,
        rows: 3,
        class: "mt-1 block w-full rounded-md bg-gray-700 border-gray-600 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2",
        placeholder: "Observações sobre a tarefa (opcional)" %>
  </div>

  <p class="text-xs text-gray-400"><span class="text-red-400">*</span> campos obrigatórios</p>

  <div class="flex flex-col sm:flex-row gap-3 pt-4">
    <%= form.submit "Criar Tarefa",
        class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md text-sm font-medium transition min-h-[44px] cursor-pointer",
        data: { action: "click->project-selector#validateBeforeSubmit" } %>
    <%= link_to "Cancelar", root_path,
        class: "bg-gray-600 hover:bg-gray-500 text-white px-6 py-2 rounded-md text-sm font-medium transition min-h-[44px] inline-flex items-center justify-center" %>
  </div>
<% end %>
