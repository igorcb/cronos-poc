<div class="max-w-7xl mx-auto">
  <section aria-labelledby="tasks-heading">
    <div class="flex items-center justify-between mb-6">
      <h1 id="tasks-heading" class="text-2xl font-bold text-white">Tarefas do Mês</h1>
      <%= link_to "Nova Tarefa", new_task_path,
          class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium transition min-h-[44px] inline-flex items-center",
          aria: { label: "Criar nova tarefa" } %>
    </div>

    <%= render "tasks/filters" %>

    <turbo-frame id="time_entries_list" data-turbo-action="advance">
      <% if @is_filtered %>
        <div id="filter_count_message" class="mb-4 text-sm text-blue-400" aria-live="polite" aria-atomic="true">
          Mostrando <%= @filtered_count %> <%= @filtered_count == 1 ? "entrada" : "entradas" %> (filtrado)
        </div>
      <% end %>

      <%= render "tasks/daily_total", daily_total: @daily_total %>

      <%= render "tasks/company_monthly_totals", totals: @company_monthly_totals %>

      <div class="bg-gray-800 shadow-sm rounded-lg border border-gray-700 overflow-hidden">
        <% if @tasks.empty? %>
          <div class="px-6 py-12 text-center text-gray-400" role="status">
            <p>Nenhuma tarefa encontrada para <%= @period_label %>.</p>
          </div>
        <% else %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-700" aria-label="Lista de tarefas">
              <caption class="sr-only">Tarefas de <%= @period_label %></caption>
              <thead class="bg-gray-900">
                <tr>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Data</th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Tarefa</th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Empresa</th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Projeto</th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Estimado</th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Validado</th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Valor</th>
                </tr>
              </thead>
              <tbody class="bg-gray-800 divide-y divide-gray-700">
                <% @tasks.each do |task| %>
                  <%= render TaskCardComponent.new(task: task) %>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </turbo-frame>
  </section>
</div>
