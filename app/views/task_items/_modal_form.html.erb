<turbo-frame id="modal">
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
       data-controller="modal"
       data-action="keydown.escape@window->modal#close click->modal#closeOnOverlayClick"
       role="dialog"
       aria-modal="true"
       aria-labelledby="modal-title">

    <div class="bg-gray-900 rounded-xl shadow-2xl ring-1 ring-gray-600 w-full max-w-lg mx-4 max-h-[90vh] flex flex-col">
      <!-- Header -->
      <div class="flex items-start justify-between p-6 border-b border-gray-700/80 bg-gray-800/50 rounded-t-xl">
        <div>
          <h2 id="modal-title" class="text-white font-bold text-lg"><%= task.display_name %></h2>
          <p class="text-gray-400 text-sm mt-1"><%= task.company.name %> · <%= task.project.name %></p>
        </div>
        <button data-action="modal#close"
                aria-label="Fechar modal"
                class="text-gray-400 hover:text-white transition ml-4 text-xl leading-none">×</button>
      </div>

      <!-- Scrollable body -->
      <div class="overflow-y-auto flex-1 p-6 space-y-6">
        <!-- Formulário -->
        <%= form_with model: [task, task_item],
                      html: { novalidate: true },
                      data: {
                        turbo_frame: "task-items-list-#{task.id}",
                        controller: "task-item-hours",
                        task_item_hours_preview_id_value: "hours-preview-#{task.id}",
                        task_item_hours_value_id_value: "hours-value-#{task.id}"
                      } do |f| %>

          <% if task_item.errors.any? %>
            <div id="task_item_errors_<%= task.id %>" class="bg-red-900/50 border border-red-700 rounded p-3" role="alert">
              <ul class="list-disc list-inside text-red-300 text-sm space-y-1">
                <% task_item.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :start_time, "Hora Início", class: "block text-sm font-medium text-gray-400 mb-1" %>
              <%= f.time_field :start_time,
                               required: true,
                               class: "w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500",
                               data: { action: "change->task-item-hours#calculate" } %>
            </div>
            <div>
              <%= f.label :end_time, "Hora Fim", class: "block text-sm font-medium text-gray-400 mb-1" %>
              <%= f.time_field :end_time,
                               required: true,
                               class: "w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500",
                               data: { action: "change->task-item-hours#calculate" } %>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :work_date, "Data", class: "block text-sm font-medium text-gray-400 mb-1" %>
              <%= f.date_field :work_date,
                               value: task_item.work_date || Date.current,
                               required: true,
                               class: "w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" %>
            </div>
            <div>
              <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-400 mb-1" %>
              <%= f.select :status,
                           [["Pendente", "pending"], ["Concluído", "completed"]],
                           { selected: task_item.status || "pending" },
                           class: "w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" %>
            </div>
          </div>

          <div id="hours-preview-<%= task.id %>" class="text-blue-400 text-sm font-medium hidden">
            Horas trabalhadas: <span id="hours-value-<%= task.id %>"></span>
          </div>

          <%= f.submit "Lançar Horas",
                       class: "w-full mt-2 bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 px-4 rounded transition cursor-pointer" %>
        <% end %>

        <!-- Histórico -->
        <div>
          <h3 class="text-gray-400 text-sm font-medium mb-3 uppercase tracking-wider">Histórico de Horas</h3>
          <turbo-frame id="task-items-list-<%= task.id %>">
            <%= render "task_items/list", task_items: task_items %>
          </turbo-frame>
        </div>
      </div>

      <!-- Footer com botão Fechar -->
      <div class="flex justify-end p-4 border-t border-gray-700">
        <button type="button"
                data-action="modal#close"
                class="bg-gray-600 hover:bg-gray-500 text-white px-6 py-2 rounded-md text-sm font-medium transition min-h-[44px] inline-flex items-center justify-center">
          Fechar
        </button>
      </div>
    </div>
  </div>
</turbo-frame>
