<span id="task-items-total-<%= task.id %>" class="flex items-center">
  <% if task_items.any? %>
    <span class="text-gray-400 text-sm mr-1">Total:</span>
    <span class="text-blue-400 font-semibold text-sm"><%= minutes_to_hm((task_items.sum { |i| ((i.end_time - i.start_time) / 60).floor })) %></span>
  <% end %>
</span>
