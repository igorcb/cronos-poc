<% if task_items.any? %>
  <ul class="space-y-2" role="list">
    <% task_items.each do |item| %>
      <li id="task_item_<%= item.id %>" class="bg-gray-700 rounded p-3 text-sm">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3 text-gray-300">
            <span class="text-white font-medium"><%= item.work_date&.strftime("%d/%m/%Y") %></span>
            <span><%= item.start_time&.strftime("%H:%M") %> – <%= item.end_time&.strftime("%H:%M") %></span>
            <span class="text-blue-400 font-medium"><%= minutes_to_hm(((item.end_time - item.start_time) / 60).floor) %></span>
          </div>
          <div class="flex items-center gap-2">
            <%= render StatusBadgeComponent.new(status: item.status.to_s) %>
            <button type="button"
                    aria-label="Editar lançamento"
                    data-edit-start="<%= item.start_time&.strftime("%H:%M") %>"
                    data-edit-end="<%= item.end_time&.strftime("%H:%M") %>"
                    data-edit-date="<%= item.work_date %>"
                    data-edit-status="<%= item.status %>"
                    data-edit-url="<%= task_task_item_path(item.task, item) %>"
                    class="inline-flex items-center justify-center w-6 h-6 bg-gray-600 hover:bg-gray-500 text-white rounded transition">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </button>
          </div>
        </div>
      </li>
    <% end %>
  </ul>
  <div class="flex justify-end items-center mt-3 pt-3 border-t border-gray-700">
    <span class="text-gray-400 text-sm mr-2">Total:</span>
    <span class="text-blue-400 font-semibold text-sm"><%= minutes_to_hm((task_items.sum { |i| ((i.end_time - i.start_time) / 60).floor })) %></span>
  </div>
<% else %>
  <p class="text-gray-500 text-sm italic" role="status">Nenhum lançamento ainda</p>
<% end %>
