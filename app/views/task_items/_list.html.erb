<% if task_items.any? %>
  <ul class="space-y-2" role="list">
    <% task_items.each do |item| %>
      <li id="task_item_<%= item.id %>" class="bg-gray-700 rounded p-3 text-sm">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3 text-gray-300">
            <span class="text-white font-medium"><%= item.work_date&.strftime("%d/%m/%Y") %></span>
            <span><%= item.start_time&.strftime("%H:%M") %> – <%= item.end_time&.strftime("%H:%M") %></span>
            <span class="text-blue-400 font-medium"><%= hours_to_hm(item.hours_worked) %></span>
          </div>
          <%= render StatusBadgeComponent.new(status: item.status.to_s) %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-gray-500 text-sm italic" role="status">Nenhum lançamento ainda</p>
<% end %>
