<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-gray-900">
  <div class="max-w-md w-full space-y-8">
    <!-- Logo/Title -->
    <div class="text-center">
      <h2 class="text-4xl font-bold text-white mb-2">
        Cronos POC
      </h2>
      <p class="text-gray-300">
        Time Tracking System
      </p>
    </div>

    <!-- Login Form -->
    <div class="bg-gray-800 rounded-lg shadow-md p-8 border border-gray-700">
      <h3 class="text-2xl font-semibold text-white mb-6 text-center">
        Entrar no sistema
      </h3>

      <%= form_with url: session_path, class: "space-y-6" do |form| %>
        <!-- Email Field -->
        <div>
          <%= form.label :email, "Email", class: "block text-sm font-medium text-gray-300 mb-2" %>
          <%= form.email_field :email,
              required: true,
              autofocus: true,
              autocomplete: "username",
              placeholder: "seu@email.com",
              value: params[:email],
              class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <!-- Password Field -->
        <div>
          <%= form.label :password, "Senha", class: "block text-sm font-medium text-gray-300 mb-2" %>
          <%= form.password_field :password,
              required: true,
              autocomplete: "current-password",
              placeholder: "Digite sua senha",
              maxlength: 72,
              class: "w-full min-h-[44px] px-3 py-2 bg-gray-700 border border-gray-600 text-white rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <!-- Submit Button -->
        <div>
          <%= form.submit "Entrar",
              class: "w-full min-h-[44px] bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md transition focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
        </div>
      <% end %>

      <% if google_oauth_enabled? %>
        <!-- Divisor "ou" + Botão Google (story 9.1) -->
        <div class="flex items-center gap-3 my-6" role="separator" aria-label="ou">
          <hr class="flex-1 border-gray-600" aria-hidden="true">
          <span class="text-gray-400 text-sm" aria-hidden="true">ou</span>
          <hr class="flex-1 border-gray-600" aria-hidden="true">
        </div>

        <%= button_to "/auth/google_oauth2",
              method: :post,
              data: { turbo: false },
              class: "w-full min-h-[44px] flex items-center justify-center gap-3 bg-white hover:bg-gray-100 text-gray-900 font-medium py-2 px-4 rounded-md border border-gray-300 transition focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" do %>
          <%= image_tag "google_g.svg", alt: "", class: "w-5 h-5", aria: { hidden: "true" } %>
          <span>Entrar com Google</span>
        <% end %>
      <% end %>
    </div>

    <!-- Footer Note -->
    <p class="text-center text-sm text-gray-400">
      MVP Single-User System
    </p>
  </div>
</div>
