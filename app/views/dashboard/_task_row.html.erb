<tr id="task_row_<%= task.id %>" class="hover:bg-gray-700 transition-colors">
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.start_date&.strftime("%d/%m/%Y") %></td>
  <td class="px-4 py-3 text-sm text-white font-medium"><%= task.display_name %></td>
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.company&.name %></td>
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.project&.name %></td>
  <td class="px-4 py-3"><%= render StatusBadgeComponent.new(status: task.status.to_s) %></td>
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.estimated_hours_hm %></td>
  <td class="px-4 py-3 flex items-center justify-end gap-1">
    <% if task.delivered? %>
      <span role="button"
            class="inline-flex items-center justify-center w-8 h-8 bg-gray-700 text-gray-500 rounded cursor-not-allowed"
            aria-label="Lançar horas indisponível — tarefa entregue"
            aria-disabled="true">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </span>
    <% else %>
      <%= link_to new_task_task_item_path(task),
                  data: { turbo_frame: "modal" },
                  class: "inline-flex items-center justify-center w-8 h-8 bg-blue-600 hover:bg-blue-500 text-white rounded transition",
                  aria: { label: "Lançar horas para #{task.display_name}" } do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      <% end %>
    <% end %>

    <% if task.completed? %>
      <%= button_to deliver_task_path(task),
                    method: :patch,
                    form_class: "inline-flex",
                    class: "inline-flex items-center justify-center w-8 h-8 bg-green-600 hover:bg-green-500 text-white rounded transition",
                    aria: { label: "Marcar #{task.display_name} como entregue" },
                    data: { turbo_stream: true } do %>
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
        </svg>
      <% end %>
    <% else %>
      <span role="button"
            class="inline-flex items-center justify-center w-8 h-8 bg-gray-700 text-gray-500 rounded cursor-not-allowed"
            aria-label="Entregar indisponível — status: <%= task.status %>"
            aria-disabled="true">
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
        </svg>
      </span>
    <% end %>
  </td>
</tr>
