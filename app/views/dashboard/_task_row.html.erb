<tr class="hover:bg-gray-700 transition-colors cursor-pointer"
    data-controller="row-link"
    data-row-link-url-value="<%= new_task_task_item_path(task) %>"
    data-row-link-frame-value="modal"
    data-action="click->row-link#navigate keydown.enter->row-link#navigate"
    tabindex="0"
    role="row"
    aria-label="Lançar horas para <%= task.display_name %>">
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.start_date&.strftime("%d/%m/%Y") %></td>
  <td class="px-4 py-3 text-sm text-white font-medium">
    <%= link_to task.display_name, new_task_task_item_path(task),
                data: { turbo_frame: "modal" },
                class: "hover:text-blue-400 transition" %>
  </td>
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.company&.name %></td>
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.project&.name %></td>
  <td class="px-4 py-3"><%= render StatusBadgeComponent.new(status: task.status.to_s) %></td>
  <td class="px-4 py-3 text-sm text-gray-300"><%= task.estimated_hours_hm %></td>
</tr>
