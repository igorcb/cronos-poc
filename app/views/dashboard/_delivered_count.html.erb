<div id="kpi-entregas-mes" class="bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-700" aria-label="Entregas do Mês: <%= monthly_delivered_count %>">
  <div class="flex items-center">
    <div class="flex-shrink-0 bg-blue-900 rounded-md p-3">
      <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>
    <div class="ml-4">
      <p class="text-sm font-medium text-gray-400">Entregas do Mês</p>
      <p class="text-2xl font-semibold text-white"><%= monthly_delivered_count %></p>
    </div>
  </div>
</div>
