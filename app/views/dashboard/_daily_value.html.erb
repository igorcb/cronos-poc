<div id="dashboard_daily_value" class="bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-700" aria-label="Valor Hoje: <%= number_to_currency(daily_value, unit: 'R$', separator: ',', delimiter: '.') %>">
  <div class="flex items-center">
    <div class="flex-shrink-0 bg-yellow-900 rounded-md p-3">
      <svg class="h-6 w-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
      </svg>
    </div>
    <div class="ml-4">
      <p class="text-sm font-medium text-gray-400">Valor Hoje</p>
      <p class="text-2xl font-semibold text-white"><%= number_to_currency(daily_value, unit: "R$", separator: ",", delimiter: ".") %></p>
    </div>
  </div>
</div>
