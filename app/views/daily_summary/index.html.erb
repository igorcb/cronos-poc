<% content_for :title, "Resumo Diário — Cronos POC" %>

<div class="w-full">
  <section aria-labelledby="daily-summary-heading">
    <div class="flex items-center justify-between mb-6">
      <h1 id="daily-summary-heading" class="text-2xl font-bold text-white">Resumo Diário</h1>
    </div>

    <!-- Filtro de mês -->
    <div class="bg-gray-800 shadow-sm rounded-lg p-4 sm:p-6 border border-gray-700 mb-6">
      <%= form_with url: daily_summary_path, method: :get, html: { novalidate: true } do |f| %>
        <div class="flex flex-col sm:flex-row sm:items-end gap-3">
          <div class="flex-1 sm:max-w-xs">
            <%= f.label :month, "Mês:", class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.select :month, @month_options, { selected: @selected_month },
                onchange: "this.form.requestSubmit()",
                class: "w-full min-h-[44px] bg-gray-700 border border-gray-600 text-white rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- KPIs do mês -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6" aria-label="KPIs do mês selecionado">
      <div class="bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-700">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-blue-900 rounded-md p-3">
            <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-400">Cards no mês</p>
            <p id="kpi-cards" class="text-2xl font-semibold text-white"><%= @kpi_cards %></p>
          </div>
        </div>
      </div>
      <div class="bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-700">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-blue-900 rounded-md p-3">
            <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-400">Horas no mês</p>
            <p id="kpi-hours" class="text-2xl font-semibold text-white"><%= hours_to_hm(@kpi_hours) %></p>
          </div>
        </div>
      </div>
      <div class="bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-700">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-blue-900 rounded-md p-3">
            <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-400">Valor no mês</p>
            <p id="kpi-value" class="text-2xl font-semibold text-white"><%= number_to_currency(@kpi_value, unit: "R$ ", separator: ",", delimiter: ".") %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabela diária -->
    <div class="bg-gray-800 shadow-sm rounded-lg border border-gray-700 overflow-hidden">
      <% if @daily_rows.empty? %>
        <div class="px-6 py-12 text-center text-gray-400" role="status" aria-live="polite" aria-atomic="true">
          <p>Nenhum lançamento encontrado para <%= @selected_month_label %>.</p>
        </div>
      <% else %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-700" aria-label="Resumo diário do mês">
            <caption class="sr-only">Resumo diário de <%= @selected_month_label %></caption>
            <thead class="bg-gray-900">
              <tr>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Data</th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Qtde</th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Horas</th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Valor</th>
              </tr>
            </thead>
            <tbody class="bg-gray-800 divide-y divide-gray-700">
              <% @daily_rows.each do |date, qtde, hours, value| %>
                <tr>
                  <td class="px-4 py-3 text-sm text-gray-300"><%= l(date) %></td>
                  <td class="px-4 py-3 text-sm text-gray-300"><%= qtde %></td>
                  <td class="px-4 py-3 text-sm text-gray-300"><%= hours_to_hm(hours) %></td>
                  <td class="px-4 py-3 text-sm text-gray-300"><%= number_to_currency(value, unit: "R$ ", separator: ",", delimiter: ".") %></td>
                </tr>
              <% end %>
            </tbody>
            <tfoot class="bg-gray-900">
              <tr>
                <th scope="row" class="px-4 py-3 text-left text-sm font-semibold text-white">Total</th>
                <td class="px-4 py-3 text-sm font-semibold text-white"><%= @kpi_cards %></td>
                <td class="px-4 py-3 text-sm font-semibold text-white"><%= hours_to_hm(@kpi_hours) %></td>
                <td class="px-4 py-3 text-sm font-semibold text-white"><%= number_to_currency(@kpi_value, unit: "R$ ", separator: ",", delimiter: ".") %></td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% end %>
    </div>
  </section>
</div>
