<%= form_with(model: company, class: "space-y-6",
    data: { controller: "form-validation" },
    html: { novalidate: true }) do |form| %>
  <% if company.errors.any? %>
    <div role="alert" style="background-color: #7f1d1d; border: 1px solid #991b1b; color: #fef3c7;" class="px-4 py-3 rounded-md">
      <h2 class="font-bold mb-2">
        <%= pluralize(company.errors.count, "erro encontrado:", "erros encontrados:") %>
      </h2>
      <ul class="list-disc list-inside space-y-1">
        <% company.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-300 mb-1" do %>
      Nome
      <span class="text-red-400 ml-1" aria-hidden="true">*</span>
    <% end %>
    <%= form.text_field :name,
        "aria-required": "true",
        "aria-describedby": company.errors[:name].any? ? "company_name_error" : nil,
        "aria-invalid": company.errors[:name].any? ? "true" : nil,
        data: { action: "input->form-validation#clearError" },
        class: "mt-1 block w-full min-h-[44px] rounded-md bg-gray-700 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border #{company.errors[:name].any? ? 'border-red-500' : 'border-gray-600'}",
        placeholder: "Nome da empresa" %>
    <% if company.errors[:name].any? %>
      <span id="company_name_error" role="alert" class="mt-1 text-sm text-red-400">
        <%= company.errors[:name].first %>
      </span>
    <% end %>
  </div>

  <div>
    <%= form.label :hourly_rate, class: "block text-sm font-medium text-gray-300 mb-1" do %>
      Taxa R$/hora
      <span class="text-red-400 ml-1" aria-hidden="true">*</span>
    <% end %>
    <%= form.number_field :hourly_rate,
        "aria-required": "true",
        step: 0.01,
        min: 0.01,
        "aria-describedby": company.errors[:hourly_rate].any? ? "company_hourly_rate_error" : nil,
        "aria-invalid": company.errors[:hourly_rate].any? ? "true" : nil,
        data: { action: "input->form-validation#clearError" },
        class: "mt-1 block w-full min-h-[44px] rounded-md bg-gray-700 text-white shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border #{company.errors[:hourly_rate].any? ? 'border-red-500' : 'border-gray-600'}",
        placeholder: "150.00" %>
    <% if company.errors[:hourly_rate].any? %>
      <span id="company_hourly_rate_error" role="alert" class="mt-1 text-sm text-red-400">
        <%= company.errors[:hourly_rate].first %>
      </span>
    <% end %>
  </div>

  <p class="text-xs text-gray-400"><span class="text-red-400">*</span> campos obrigatórios</p>

  <div class="flex flex-col sm:flex-row gap-3 pt-4">
    <%= form.submit "Salvar",
        class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md text-sm font-medium transition min-h-[44px] cursor-pointer" %>
    <%= link_to "Cancelar", companies_path,
        class: "bg-gray-600 hover:bg-gray-500 text-white px-6 py-2 rounded-md text-sm font-medium transition min-h-[44px] inline-flex items-center justify-center" %>
  </div>
<% end %>
